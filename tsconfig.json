{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "es2022",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": "./",
    "outDir": "dist",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "paths": {
      "@root/*": ["./../src/*"],
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "vite/client",
      "react-syntax-highlighter"
    ],
    "ignoreDeprecations": "6.0"
  }
}