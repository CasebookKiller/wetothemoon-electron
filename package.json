{
  "name": "electron-forge-vite-typescript-react-template",
  "productName": "electron-forge-vite-typescript-react-template",
  "version": "1.0.0",
  "description": "Template of Electron Forge application with Vite, TypeScript and React",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "dev:main": "vite --config vite.render.config.ts",
    "dev:llama": "vite --config vite.llama.config.ts",
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:llama\"",
    "build:main": "vite build --config vite.render.config.ts",
    "build:llama": "vite build --config vite.llama.config.ts",
    "build": "npm run build:main && npm run build:llama"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "@electron-forge/plugin-fuses": "^7.6.0",
    "@electron-forge/plugin-vite": "^7.6.0",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "prettier": "^3.4.1",
    "terser": "^5.46.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vite-plugin-mkcert": "^1.17.10",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "keywords": [],
  "author": {
    "name": "casebook{killer}",
    "email": "casebookkiller@yandex.ru"
  },
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.102.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron-squirrel-startup": "^1.0.1",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^18.3.1",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^7.14.0"
  }
}
