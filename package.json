{
  "name": "wetothemoon-electron",
  "productName": "wetothemoon-electron",
  "version": "1.0.0",
  "description": "Template of Electron Forge application with Vite, TypeScript and React",
  "main": "dist/main/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "dev:main": "vite --config vite.render.config.ts",
    "dev:ai": "vite --config vite.ai.config.ts",
    "dev": "concurrently \"npm run dev:ai\" \"npm run dev:main\"",
    "build:main": "vite build --config vite.render.config.ts",
    "build:ai": "vite build --config vite.ai.config.ts",
    "build": "npm run build:main && npm run build:ai",
    "cache:clean": "rm -rf node_modules/.vite && rm -rf dist && rm -rf .cache && rm -rf package-lock.json"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^2.1.1",
    "@eslint/js": "^10.0.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/node": "^25.5.2",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "eslint": "^10.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "prettier": "^3.4.1",
    "rollup-plugin-copy": "^3.5.0",
    "terser": "^5.46.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-static-copy": "^4.1.0",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "keywords": [],
  "author": {
    "name": "casebook{killer}",
    "email": "casebookkiller@yandex.ru"
  },
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.1",
    "@supabase/supabase-js": "^2.103.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "highlight.js": "^11.11.1",
    "ignore": "^7.0.5",
    "ollama": "^0.6.3",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primereact": "^10.9.7",
    "react": "^19.2.5",
    "react-bootstrap-icons": "^1.11.6",
    "react-copy-to-clipboard": "^5.1.1",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-starry-night": "^2.2.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-toc": "^9.0.0",
    "typescript-eslint": "^8.58.1",
    "unified": "^11.0.5",
    "vite-plugin-mkcert": "^1.17.12",
    "ws": "^8.20.0"
  }
}
